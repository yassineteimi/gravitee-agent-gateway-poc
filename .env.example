# ---------------------------------------------------------------------------
# Copy to .env and fill in. .env is gitignored and NEVER committed.
# Secrets are injected as Kubernetes Secrets by scripts in poc/scripts/.
# This file documents the variables; it carries NO real values.
# ---------------------------------------------------------------------------

# Gravitee Enterprise trial license. Unlocks the AI Gateway and Kafka Gateway
# (Gates 2 and 3). Request a 14-day trial from https://www.gravitee.io/ and
# paste the base64 license key here. Without it, only Gate 1 (OSS) works.
GRAVITEE_LICENSE=

# Gravitee Management API admin credentials. Used by the Kubernetes Operator's
# ManagementContext to push declared APIs into the control plane. Defaults are
# the chart's admin/admin; injected as a Kubernetes Secret by the inject-secrets
# script, never committed.
GRAVITEE_ADMIN_USER=admin
GRAVITEE_ADMIN_PASSWORD=admin

# NVIDIA hosted NIM API key (starts with nvapi-) for Gate 2 LLM traffic.
# Free key from https://build.nvidia.com/. OpenAI-compatible endpoint.
NVIDIA_API_KEY=

# Models for Gate 2 (filled in when we build the AI / Agent Gateway).
# NIM_CHAT_MODEL=meta/llama-3.1-8b-instruct

# Additional gate secrets (JWT signing, Kafka credentials) are added to this
# file as each milestone introduces them.
